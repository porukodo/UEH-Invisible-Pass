# Must match server's QR_AES_KEY - shared secret for offline QR encryption (FR11)
VITE_QR_AES_KEY=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa

# Must match server's GATE_HMAC_SECRET - used by the gate scanner page (FR14/NFR03)
VITE_GATE_HMAC_SECRET=change_me_gate_hmac_secret

# Backend API base URL. Leave empty for local dev (uses Vite's /api proxy).
# In production (Vercel), set to your deployed backend project's origin, e.g.
# https://ueh-invisible-pass-server.vercel.app
VITE_API_URL=
