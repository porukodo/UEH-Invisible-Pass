# Server
PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# MySQL (XAMPP)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=ueh_invisible_pass
# Set to "true" for TiDB Cloud Serverless / other TLS-required MySQL hosts
DB_SSL=false

# Auth
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=2h

# Email OTP (Nodemailer / Gmail SMTP or any SMTP provider)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="UEH Invisible Pass <no-reply@ueh-invisible-pass.local>"

# VietQR top-up
VIETQR_BANK_ID=970415
VIETQR_ACCOUNT_NO=
VIETQR_ACCOUNT_NAME=

# Gate <-> Server signing
GATE_HMAC_SECRET=change_me_gate_hmac_secret

# SePay webhook auth (Authorization: Apikey <SEPAY_API_KEY>)
SEPAY_API_KEY=

# Secret for the Vercel Cron -> /api/cron/topup-retry endpoint
# (Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=

# QR payload encryption (AES-256-CBC key, 64 hex chars = 32 bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
QR_AES_KEY=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
